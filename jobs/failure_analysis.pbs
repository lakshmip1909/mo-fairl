#!/bin/bash
#PBS -N mo_fairl_failure
#PBS -l walltime=01:00:00
#PBS -l ncpus=4
#PBS -l mem=16gb
#PBS -l ngpus=1
#PBS -j oe
#PBS -o logs/failure_analysis.log

set -e
cd "$PBS_O_WORKDIR"

mkdir -p logs outputs/failure_examples outputs/metrics outputs/plots

module load anaconda3/personal 2>/dev/null || true
module load cuda/12.1 2>/dev/null || true

source ~/miniconda3/etc/profile.d/conda.sh
conda activate irlf

export PYTHONPATH=$PBS_O_WORKDIR:$PYTHONPATH

echo "=========================================="
echo "  MO-FAIRL: Failure Analysis"
echo "  Job ID: $PBS_JOBID"
echo "  Start : $(date)"
echo "=========================================="

python src/failure_analysis.py --config configs/default.yaml

echo "Failure analysis complete: $(date)"
